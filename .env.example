SNIPTAIL_BOT_CONFIG_PATH=../../sniptail.bot.toml
SNIPTAIL_WORKER_CONFIG_PATH=../../sniptail.worker.toml
SNIPTAIL_DRY_RUN=0
# Optional runtime channel filter for bot process (for example: slack, discord, or slack,discord).
SNIPTAIL_CHANNELS=
# Optional queue transport override: redis or inproc (default: redis).
# Use inproc together with `sniptail local`.
QUEUE_DRIVER=
# Optional. Redis URL used by bot/worker when queue_driver=redis (falls back to redis_url in TOML when unset).
REDIS_URL=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=
DISCORD_BOT_TOKEN=
# Optional when using Codex CLI with existing authentication. Otherwise required for Codex execution.
OPENAI_API_KEY=
# Optional OpenCode overrides. Server auth value should be the complete Authorization header.
OPENCODE_EXECUTION_MODE=
OPENCODE_SERVER_URL=
OPENCODE_SERVER_AUTH_HEADER_ENV=
OPENCODE_AUTH_HEADER=
OPENCODE_AGENT=
OPENCODE_STARTUP_TIMEOUT_MS=
OPENCODE_DOCKER_STREAM_LOGS=
OPENCODE_DOCKERFILE_PATH=
OPENCODE_DOCKER_IMAGE=
OPENCODE_DOCKER_BUILD_CONTEXT=
# Optional future /agent command scalar worker overrides.
AGENT_COMMAND_ENABLED=
AGENT_COMMAND_DEFAULT_WORKSPACE=
AGENT_COMMAND_DEFAULT_AGENT_PROFILE=
AGENT_COMMAND_INTERACTION_TIMEOUT_MS=
AGENT_COMMAND_OUTPUT_DEBOUNCE_MS=
# Optional; required for GitLab merge requests or repository bootstrap.
GITLAB_TOKEN=
# Optional; required for GitHub pull requests or repository bootstrap.
GITHUB_API_TOKEN=
# Required when JOB_REGISTRY_DB=pg.
JOB_REGISTRY_PG_URL=
# Optional override when JOB_REGISTRY_DB=redis (falls back to REDIS_URL when set).
JOB_REGISTRY_REDIS_URL=
# Optional command run in each prepared worktree (for example: pnpm install --prefer-offline --no-lockfile).
WORKTREE_SETUP_COMMAND=
# Optional worker concurrency overrides (positive integers).
JOB_CONCURRENCY=
BOOTSTRAP_CONCURRENCY=
WORKER_EVENT_CONCURRENCY=
# Optional namespaced debug logging. Comma-separated list of namespaces (e.g. slack), or * to enable all.
SNIPTAIL_DEBUG=
