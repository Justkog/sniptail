FROM node:22-bookworm-slim

ARG PNPM_VERSION=10.5.0

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates curl git openssh-client bash \
    ripgrep patch procps less \
  && rm -rf /var/lib/apt/lists/*

RUN useradd -m -s /bin/bash opencode \
  && mkdir -p /home/opencode/.cache/node/corepack /home/opencode/.npm-global \
  && chown -R opencode:opencode /home/opencode

RUN corepack enable

USER opencode
WORKDIR /home/opencode

ENV XDG_CACHE_HOME=/home/opencode/.cache
ENV COREPACK_HOME=/home/opencode/.cache/node/corepack
ENV COREPACK_DEFAULT_TO_LATEST=0
ENV NPM_CONFIG_PREFIX=/home/opencode/.npm-global
ENV PATH=/home/opencode/.npm-global/bin:${PATH}

RUN corepack prepare "pnpm@${PNPM_VERSION}" --activate \
  && npm install -g "opencode-ai" "pnpm@${PNPM_VERSION}" \
  && test "$(pnpm --version)" = "${PNPM_VERSION}" \
  && test "$(corepack pnpm --version)" = "${PNPM_VERSION}" \
  && opencode --version

ENTRYPOINT ["opencode"]
